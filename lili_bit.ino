  display.setTextColor(SSD1306_WHITE);

  display.drawBitmap(70, 2, logo, 60, 60, SSD1306_WHITE);

  display.setTextSize(1);
  display.setCursor(5, 55);
  display.println("by bas_ic");
};
void bot_screen_wifi(){
  display.setCursor(5, 10);
  display.println("try WIFI");
  display.display();
};
void bot_screen_api(){
  display.setCursor(5, 25);
  display.println("try API");
  display.display();
};
void home_screen(){
  display.drawBitmap(66, 0, qr_code, 62, 62, SSD1306_WHITE);
  display.setCursor(0, 5);
  display.println(formatSOL(balance));
  display.setCursor(0, 15);
  display.println("balance");
};
void take_screen(){
  display.setCursor(0, 35);
  display.setTextSize(1);
  display.println(formatSOL(take));
  display.setCursor(0, 45);
  display.println("take");
  display.setTextSize(1);
};
void update_screen(){
  display.setCursor(0, 55);
  display.println("update..");
  digitalWrite(LED_BUILTIN, LOW);
};
void end_screen(){
  display.display();
}


void setup() {
  pinMode(LED_BUILTIN, OUTPUT);
  
  Serial.begin(115200);
  Wire.begin();

  run_screen();

  randomSeed(analogRead(0));

  clear_screen();

  bot_screen();
  
  bot_screen_wifi();
  
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    //Serial.print(".");
  }
  getBalances();

  bot_screen_api();
  

  //Serial.print("IP: ");
  //Serial.println(WiFi.localIP());

  delay(2000);
  clear_screen();

}

void loop() {
  digitalWrite(LED_BUILTIN, HIGH); 

  work = work + 1;

  if(work == 100 or work == 200 or work == 300 or work >= 400){
    clear_screen();
    home_screen();
    
    if(take != 0 and take != balance){

      take_screen();
      digitalWrite(LED_BUILTIN, LOW); 
    }

      if(work >= 400){
      
      getBalances();
      if(balance != history){
        take = balance - history;
        history = balance;
      }

      work = 0;
      update_screen();
      
    
    }
    end_screen();
  }
  depression_check();
  yield();
  delay(100);
  
};

void setup() {
  pinMode(LED_BUILTIN, OUTPUT);
  
  Serial.begin(115200);
  Wire.begin();

  run_screen();

  randomSeed(analogRead(0));

  clear_screen();

  bot_screen();
  
  bot_screen_wifi();
  
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    //Serial.print(".");
  }
  getBalances();

  bot_screen_api();
  

  //Serial.print("IP: ");
  //Serial.println(WiFi.localIP());

  delay(2000);
  clear_screen();

}

void loop() {
  digitalWrite(LED_BUILTIN, HIGH); 

  work = work + 1;

  if(work == 100 || work == 200 || work == 300 || work >= 400){
    clear_screen();
    home_screen();
    
    if(take != 0 && take != balance){

      take_screen();
      digitalWrite(LED_BUILTIN, LOW); 
    }

      if(work >= 400){
      
      getBalances();
      if(balance != history){
        take = balance - history;
        history = balance;
      }

      work = 0;
      update_screen();
      
    
    }
    end_screen();
  }
  depression_check();
  yield();
  delay(100);
  
};
